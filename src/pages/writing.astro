---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    number: "01",
    date: "March 28, 2026",
    title: "Growth doesn't happen on its own",
    excerpt: "Recently, I've been sitting with an uncomfortable truth. Growth doesn't happen on its own, you have to go looking for it. I'm rebuilding my personal site from scratch to prove it.",
    tags: ["#golang", "#buildinpublic", "#aws", "#kubernetes"],
    url: "https://www.linkedin.com/posts/anchita-hn_golang-buildinpublic-softwaredevelopment-activity-7443658194540707840-W6Di?utm_source=share&utm_medium=member_desktop&rcm=ACoAACh_PxkBJoL5rQYfA-7xq_PiW-j1zQVQXxE",
  },
];
---

<Layout title="Writing — Anchita Hari">
  <main class="writing-main">
    <header class="writing-header fade-in">
      <a href="/" class="back-link">← back</a>
      <p class="section-label">Writing</p>
      <h1 class="writing-heading">Notes from the journey</h1>
      <p class="writing-sub">Documenting what I'm learning, building, and figuring out in public</p>
    </header>

    <div class="posts-list">
      { posts.map((post, i) => (
        <a href={post.url} target="_blank" rel="noopener noreferrer" class="post-card fade-in" style={`animation-delay: ${i * 0.15}s`}>
          <div class="post-top">
            <span class="post-number">{post.number}</span>
            <span class="post-date">{post.date}</span>
          </div>
          <h2 class="post-title">{post.title}</h2>
          <p class="post-excerpt">{post.excerpt}</p>
          <div class="post-footer">
            <div class="post-tags">
              {post.tags.map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
            <span class="post-read">Read on LinkedIn →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
    .writing-main {
        max-width: 860px;
        margin: 0 auto;
        padding: 8rem 4rem 6rem;
    }

    .back-link {
        display: inline-block;
        color: var(--muted);
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        margin-bottom: 3rem;
        transition: color 0.2s;
    }

    .back-link:hover { color: var(--teal); }

    .writing-header {
        margin-bottom: 5rem;
    }

    .writing-heading {
        font-family: var(--serif);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 400;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .writing-sub {
        color: var(--muted);
        font-size: 1rem;
        max-width: 520px;
        line-height: 1.8;
    }

    .posts-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .post-card {
        display: block;
        text-decoration: none;
        border: 1px solid var(--border);
        padding: 2.5rem;
        transition: border-color 0.2s, background 0.2s;
        opacity: 0;
        animation: fadeUp 0.7s ease forwards;
    }

    .post-card:hover {
        border-color: var(--teal-dim);
        background: rgba(45, 212, 191, 0.02);
    }

    .post-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .post-number {
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.1em;
    }

    .post-date {
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.05em;
    }

    .post-title {
        font-family: var(--serif);
        font-size: clamp(1.25rem, 2.5vw, 1.75rem);
        font-weight: 400;
        color: var(--white);
        margin-bottom: 0.875rem;
        line-height: 1.3;
        transition: color 0.2s;
    }

    .post-card:hover .post-title {
        color: var(--teal);
    }

    .post-excerpt {
        color: #a8a5a0;
        font-size: 0.95rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        max-width: 640px;
    }

    .post-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .post-tag {
        font-size: 0.72rem;
        color: var(--teal);
        border: 1px solid var(--teal-dim);
        background: rgba(45, 212, 191, 0.05);
        padding: 0.2rem 0.6rem;
        border-radius: 2px;
        letter-spacing: 0.03em;
    }

    .post-read {
        font-size: 0.8rem;
        color: var(--muted);
        letter-spacing: 0.05em;
        transition: color 0.2s;
        white-space: nowrap;
    }

    .post-card:hover .post-read {
        color: var(--teal);
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .writing-main { padding: 6rem 2rem 4rem; }
        .post-footer { flex-direction: column; align-items: flex-start; }
    }
</style>